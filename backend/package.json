		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.103.0",
		"@upstash/redis": "^1.37.0",
		"hono": "^4.12.12",
		"ioredis": "^5.10.1",
		"zod": "^4.1.5"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	}
}
