# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key

# LLM providers
GROQ_API_KEY=replace-with-groq-key
ANTHROPIC_API_KEY=replace-with-anthropic-key

# Upstash Redis
UPSTASH_REDIS_URL=replace-with-upstash-redis-url
UPSTASH_REDIS_TOKEN=replace-with-upstash-token

# Local Redis (integration tests)
REDIS_URL=redis://127.0.0.1:6379/0

# App runtime
JWT_SECRET=replace-with-long-random-secret
PORT=3000

