{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"types": ["bun"],
		"lib": ["ES2022", "DOM"]
	},
	"include": ["src/**/*.ts", "../shared/contracts/**/*.ts"]
}
